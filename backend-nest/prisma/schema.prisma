generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SharePermission {
  view
  edit
}

model User {
  id       BigInt        @id @default(autoincrement())
  username String        @unique
  email    String        @unique
  password String
  canvases Canvas[]
  shares   CanvasShare[]

  @@map("users")
}

model Canvas {
  id                BigInt        @id @default(autoincrement())
  userId            BigInt        @map("user_id")
  userName          String?       @map("user_name")
  title             String?
  description       String?
  nodes             Json          @default("[]")
  edges             Json          @default("[]")
  settings          Json          @default("{}")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  thumbnailFileName String?       @map("thumbnail_file_name")
  owner             User          @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  shares            CanvasShare[]

  @@index([userId])
  @@map("canvases")
}

model CanvasShare {
  id         BigInt          @id @default(autoincrement())
  canvasId   BigInt          @map("canvas_id")
  userId     BigInt          @map("user_id")
  permission SharePermission @default(view)
  canvas     Canvas          @relation(fields: [canvasId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([canvasId, userId])
  @@index([userId])
  @@map("canvas_shares")
}
